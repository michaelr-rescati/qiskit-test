# Copia questo file in ".env" e inserisci il tuo token IBM Quantum.
# Lo trovi su: https://quantum.ibm.com  ->  Account / API token
IBM_QUANTUM_TOKEN=your_token_here

# Canale: "ibm_quantum_platform" (nuova piattaforma) oppure "ibm_cloud".
IBM_CHANNEL=ibm_quantum_platform

# (Opzionale) CRN dell'istanza, se usi ibm_cloud.
# IBM_INSTANCE=
